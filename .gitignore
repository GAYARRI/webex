# Entorno virtual
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Caches de herramientas
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

