# Salidas generadas del pipeline (no commitear runs intermedios)
data/output/*
!data/output/burgos-home-golden.json

# Base de conocimiento acumulativa (generada en ejecución)
data/kb/

# Binarios y ejecutables en datos
data/ontology/*.exe
data/ontology/*.msi

